{
  "name": "@onting/story-drop-zone-element",
  "version": "0.0.0-0",
  "description": "",
  "homepage": "https://github.com/teamonting/story-drop-zone-element#readme",
  "bugs": {
    "url": "https://github.com/teamonting/story-drop-zone-element/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teamonting/story-drop-zone-element.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "browser": "npx --offline @onting/browser http://localhost:3000/test.html",
    "build": "npm run build:run --",
    "build:run": "tsup",
    "docker": "docker compose up",
    "posttest": "if test \"$CI\" = \"true\"; then docker compose down; fi",
    "pretest": "if test \"$CI\" = \"true\"; then npm run pretest:docker && npm run pretest:ready; fi",
    "pretest:docker": "npm run docker -- --detach --wait",
    "pretest:ready": "until curl -fsS http://localhost:4444/wd/hub/status | jq -e '.value.ready == true' >/dev/null; do sleep 1; done",
    "start": "concurrently --kill-others \"npm run start:*\"",
    "start:build": "npm run build -- --watch",
    "start:serve": "[ -d './public/static/' ] && rm ./public/static; ln -s ../static/ ./public/ && serve ./public/",
    "test": "node --test"
  },
  "devDependencies": {
    "@onting/browser": "^0.1.0",
    "@onting/harness": "^0.1.0",
    "@onting/stub": "^0.1.0-main",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "is-ci": "^4.1.0",
    "serve": "^14.2.6",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  }
}
